MONOPRIX_URL=https://client.monoprix.fr/monoprix-shopping/tickets

# Chrome DevTools Protocol endpoint
CDP_HOST=localhost
CDP_PORT=9222
CDP_URL=http://localhost:9222

# Where PDFs are saved
OUT_DIR=pdfs

# Auto-start a separate Chrome automation profile if Chrome is not already listening
AUTO_START_CHROME=true
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_USER_DATA_DIR=.chrome-profile
CHROME_START_TIMEOUT_SECONDS=20

# Lazy-load / scrolling behavior
SCROLL_STABLE_ROUNDS=5
SCROLL_WAIT_MS=1800

# PDF capture / page timeouts
CLICK_TIMEOUT_MS=7000
PAGE_TIMEOUT_MS=90000
